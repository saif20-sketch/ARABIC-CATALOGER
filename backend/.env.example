APP_NAME=Arabic Cataloger API
ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# اختيارية: تفعيل الاستخراج الذكي عبر Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# اختيارية: لتفعيل اقتراحات موضوعات/تصنيف بذكاء أعلى
ENABLE_LLM=true
